# ─── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=512

# ─── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
#QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=asa_support_docs

# ─── Embeddings ────────────────────────────────────────────────────────────────
DENSE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DENSE_EMBEDDING_DIM=384

# ── Reranker (TinyBERT = 3x faster than MiniLM-L6) ────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
#REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.92

# ─── Retrieval (tuned for low latency) ─────────────────────────────────────────
HYBRID_DENSE_WEIGHT=0.7
HYBRID_SPARSE_WEIGHT=0.3
RETRIEVAL_TOP_K=8
RERANKER_TOP_K=5
CHILD_CHUNK_SIZE=200
PARENT_CHUNK_SIZE=800
QUERY_VARIATIONS=1

# ─── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── LangSmith (optional) ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=asa-production-v2

# ─── Evaluation ────────────────────────────────────────────────────────────────
EVAL_DATASET_PATH=data/eval_dataset.json
